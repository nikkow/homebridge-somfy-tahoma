{
  "pluginAlias": "SomfyTaHoma",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": false,
  "schema": {
    "type": "object",
    "required": ["ip", "token"],
    "additionalProperties": false,
    "properties": {
      "ip": {
        "title": "TaHoma Platform IP",
        "type": "string",
        "placeholder": "192.168.1.100"
      },
      "token": {
        "title": "TaHoma Platform Token",
        "type": "string",
        "placeholder": "abcdef1234567890"
      }
    }
  }
}
